generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id     String @id @default(uuid())
  name   String
  email  String @unique
  role   Role @default(USER)
  createdAt DateTime @default(now())

  customerPickups Pickup[] @relation("CustomerPickups")
  agentPickups    Pickup[] @relation("AgentPickups")
}

model Pickup {
  id           String   @id @default(uuid())
  customerId   String
  agentId      String?
  pickupTime   DateTime
  location     String
  status       PickupStatus @default(PENDING)
  createdAt    DateTime @default(now())

  customer     User @relation("CustomerPickups", fields: [customerId], references: [id])
  agent        User? @relation("AgentPickups", fields: [agentId], references: [id])
}

enum Role {
  ADMIN
  USER
  AGENT
}

enum PickupStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}